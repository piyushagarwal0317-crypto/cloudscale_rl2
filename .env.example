# Inference provider selection: openai_compat or gemini
LLM_PROVIDER=openai_compat

# OpenAI-compatible settings
HF_TOKEN=
API_BASE_URL=https://router.huggingface.co/v1
MODEL_NAME=Qwen/Qwen2.5-72B-Instruct

# Gemini settings
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Firestore logging (Cloud Run)
FIRESTORE_LOGGING_ENABLED=true
FIRESTORE_COLLECTION=scale_advice_events
FIRESTORE_PROJECT_ID=

# Cloud Run deploy behavior
USE_SECRET_MANAGER=true
RUNTIME_SERVICE_ACCOUNT=

# Environment server
BENCHMARK_URL=http://localhost:8000
BENCHMARK=cloudscale_rl
MAX_STEPS=0
TEMPERATURE=0.1
MAX_TOKENS=120
